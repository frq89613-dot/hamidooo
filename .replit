modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["npm", "ci"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "npm-workspace"
expertMode = true

[postMerge]
path = "scripts/post-merge.mjs"
timeoutMs = 20000

[[ports]]
localPort = 18915
externalPort = 80
